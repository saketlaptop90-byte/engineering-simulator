rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isSuperAdmin() {
      let email = request.auth.token.email;
      return request.auth != null && (
        email == 'saketlaptop90@gmail.com' ||
        email == 'Saketlaptop90@gmail.com' ||
        email == 'saketdalal76@gmail.com'
      );
    }
    
    function hasPermission(perm) {
      return isSuperAdmin() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/employees/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/employees/$(request.auth.token.email)).data.permissions.get(perm, false) == true
      );
    }

    match /platform_config/{doc} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /employees/{email} {
      allow read: if isSuperAdmin() || hasPermission('employees');
      allow write: if isSuperAdmin() || hasPermission('employees');
    }
    
    match /model_active_sessions/{sessionId} {
      allow read: if hasPermission('analytics');
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if hasPermission('blocking');
    }

    match /community_posts/{post} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null || hasPermission('blocking');
      allow delete: if (request.auth != null && request.auth.uid == resource.data.authorId) || hasPermission('blocking');
    }
    
    match /users/{userId} {
      allow read: if request.auth != null || hasPermission('blocking');
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId) || hasPermission('blocking');
      allow delete: if isSuperAdmin();
    }
    
    match /model_requests/{reqId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || hasPermission('blocking');
      allow update: if (request.auth != null && resource.data.uid == request.auth.uid) || hasPermission('blocking');
      allow delete: if hasPermission('blocking');
    }
    
    match /activity_log/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if hasPermission('analytics');
      allow delete: if isSuperAdmin();
    }
    
    match /chats/{chatId} {
      allow read: if (request.auth != null && request.auth.uid in resource.data.participants) || hasPermission('blocking');
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants && request.resource.data.participants.size() <= 15;
      allow update: if (request.auth != null && request.auth.uid in resource.data.participants && request.resource.data.participants.size() <= 15) || hasPermission('blocking');
      allow delete: if hasPermission('blocking');
      
      match /messages/{messageId} {
        allow read: if (request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) || hasPermission('blocking');
        allow create: if request.auth != null 
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.senderUid == request.auth.uid
                      && request.resource.data.text.size() <= 500;
        allow delete: if hasPermission('blocking');
      }
    }
    
    match /sponsors/{adId} {
      allow read: if true;
      allow write: if hasPermission('blocking') || hasPermission('subscriptions');
    }
    
    match /payments/{paymentId} {
      allow read: if hasPermission('analytics') || hasPermission('subscriptions');
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSuperAdmin();
    }
  }
}
