<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contribution Center - EngiSim</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root { 
      --bg-base: #030712;
      --bg-panel: rgba(17, 24, 39, 0.8);
      --accent: #00e5ff;
      --accent-2: #8b5cf6;
      --text-main: #f9fafb;
      --glass-border: rgba(255, 255, 255, 0.1);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body, html { 
      background-color: var(--bg-base); 
      font-family: 'Outfit', sans-serif; 
      color: var(--text-main); 
    }
    
    nav { 
      padding: 1rem 3rem; background: rgba(3, 7, 18, 0.7); backdrop-filter: blur(20px); 
      border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;
    }
    .logo { font-size: 1.5rem; font-weight: 800; text-decoration: none; color: white; }
    .logo span { color: var(--accent); }

    .container {
      max-width: 800px; margin: 4rem auto; padding: 2rem;
      background: var(--bg-panel); border: 1px solid var(--glass-border); border-radius: 24px;
      backdrop-filter: blur(20px);
    }

    h1 { font-size: 2.5rem; margin-bottom: 1rem; text-align: center; }
    h1 span { color: var(--accent); }
    p.sub { text-align: center; color: var(--text-muted); margin-bottom: 3rem; }

    .form-group { margin-bottom: 1.5rem; }
    label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
    input, select, textarea {
      width: 100%; padding: 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border);
      color: white; border-radius: 12px; font-family: inherit; font-size: 1rem; outline: none; transition: border 0.3s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--accent); }
    
    .btn {
      width: 100%; background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: white; border: none; padding: 1rem; border-radius: 12px; font-size: 1.1rem; font-weight: 700;
      cursor: pointer; transition: transform 0.2s;
    }
    .btn:hover { transform: scale(1.02); }

    .success-msg {
      display: none; background: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; color: #10b981;
      padding: 1rem; border-radius: 12px; text-align: center; margin-top: 1rem;
    }
  </style>
</head>
<body>

  <nav>
    <a href="index.html" class="logo">⚙️ EngiSim <span>Contribute</span></a>
    <div><a href="simulator.html" style="color: white; text-decoration: none; font-weight: 600;">← Simulator</a></div>
  </nav>

  <div class="container">
    <h1>Submit a <span>Model</span></h1>
    <p class="sub">Help expand the Engineering Universe. Upload GLTF/GLB models or report errors.</p>
    
    <form id="contrib-form">
      <div class="form-group">
        <label>Contribution Type</label>
        <select id="ctype">
          <option value="new_model">Submit New 3D Model</option>
          <option value="correction">Suggest Correction</option>
          <option value="animation">Submit Animation Script</option>
        </select>
      </div>

      <div class="form-group">
        <label>Title / Model Name</label>
        <input type="text" id="ctitle" placeholder="e.g. SpaceX Raptor Engine" required>
      </div>

      <div class="form-group">
        <label>Asset URL (Sketchfab, Google Drive, etc.)</label>
        <input type="url" id="curl" placeholder="https://..." required>
      </div>

      <div class="form-group">
        <label>Description & Notes</label>
        <textarea id="cdesc" rows="4" placeholder="Provide details about the model, how it works, and sources..." required></textarea>
      </div>

      <button type="submit" class="btn">Submit for Review</button>
    </form>

    <div class="success-msg" id="success">
      Thank you! Your contribution has been submitted to the administrators for review. You will earn +200 EXP if approved!
    </div>
  </div>

  <script type="module" src="firebase.js"></script>
  <script type="module">
    import { db, collection, addDoc, serverTimestamp } from './firebase.js';
    
    document.getElementById('contrib-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      try {
        await addDoc(collection(db, 'contributions'), {
          type: document.getElementById('ctype').value,
          title: document.getElementById('ctitle').value,
          url: document.getElementById('curl').value,
          description: document.getElementById('cdesc').value,
          timestamp: serverTimestamp(),
          status: 'pending'
        });
        document.getElementById('contrib-form').reset();
        document.getElementById('success').style.display = 'block';
      } catch (err) {
        console.error("Error adding document: ", err);
        alert("Failed to submit. Please ensure you are logged in.");
      }
    });
  </script>
</body>
</html>