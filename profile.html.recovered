<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile - EngiSim</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
  <style>
    body { background-color: #050b14; color: white; padding-top: 80px; }
    .container { max-width: 1000px; margin: 40px auto; padding: 2rem; }
    
    .profile-header { display: flex; align-items: center; gap: 2rem; background: rgba(12,18,37,0.95); padding: 2rem; border-radius: 16px; border: 1px solid var(--glass-border); margin-bottom: 2rem; }
    .profile-pic { width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--accent); }
    .profile-info h1 { font-family: 'Space Grotesk', sans-serif; font-size: 2rem; margin-bottom: 0.5rem; }
    .profile-info p { color: var(--text-muted); font-size: 1.1rem; }
    
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
    .stat-card { background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); text-align: center; }
    .stat-card h3 { color: var(--text-muted); font-size: 1rem; margin-bottom: 0.5rem; font-weight: 500; }
    .stat-card .value { font-size: 2.5rem; font-family: 'Space Grotesk', sans-serif; color: var(--accent); }
    
    .section-title { font-size: 1.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem; }
    
    .history-list { display: flex; flex-direction: column; gap: 1rem; }
    .history-item { display: flex; justify-content: space-between; align-items: center; background: rgba(12,18,37,0.95); padding: 1.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); transition: transform 0.2s; }
    .history-item:hover { transform: translateY(-2px); border-color: rgba(0,229,255,0.3); }
    .history-info h4 { font-size: 1.2rem; margin-bottom: 0.3rem; }
    .history-info p { color: var(--text-muted); font-size: 0.9rem; }
    .history-score { font-size: 1.5rem; font-weight: 700; color: #10b981; }
    
    .premium-banner { background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(255,140,0,0.1)); border: 1px solid rgba(255,215,0,0.3); padding: 1.5rem; border-radius: 12px; text-align: center; margin-bottom: 2rem; display: none; }
    .premium-banner h3 { color: #ffd700; margin-bottom: 0.5rem; }
    
    #unauth-msg { text-align: center; padding: 4rem; font-size: 1.5rem; color: var(--text-muted); }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="logo"><a href="index.html">EngiSim <span>3D</span></a></div>
    <div class="nav-links">
      <a href="index.html">Home</a>
    </div>
  </nav>

  <div class="container" id="main-content" style="display: none;">
    <div class="premium-banner" id="premium-banner">
      <h3>🌟 Premium Scholar Unlocked</h3>
      <p>You have scored over 90% on multiple quizzes! Advanced simulation physics and features are now enabled.</p>
    </div>

    <div class="profile-header">
      <img src="https://via.placeholder.com/100" alt="Profile" class="profile-pic" id="p-pic">
      <div class="profile-info">
        <h1 id="p-name">Loading...</h1>
        <p id="p-email">Loading...</p>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <h3>Quizzes Taken</h3>
        <div class="value" id="s-total">0</div>
      </div>
      <div class="stat-card">
        <h3>Average Score</h3>
        <div class="value" id="s-avg">0%</div>
      </div>
      <div class="stat-card">
        <h3>Perfect Scores</h3>
        <div class="value" id="s-perfect" style="color: #10b981;">0</div>
      </div>
    </div>

    <h2 class="section-title">Attempt History & Growth</h2>
    <div class="history-list" id="history-list">
      <p style="color:var(--text-muted)">Loading your history...</p>
    </div>
  </div>

  <div id="unauth-msg">Please log in to view your profile and history.</div>

  <script type="module" src="profile.js"></script>
</body>
</html>
